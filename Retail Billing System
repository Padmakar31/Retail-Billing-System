def add_item_label(parent, row, text):
    lbl = Label(parent, text=text, font=('times new roman', 18, 'bold'), bg='#42A5F5', fg='Black')
    lbl.grid(row=row, column=0, pady=9, padx=10, sticky='w')
    ent = Entry(parent, font=('times new roman', 15, 'bold'), width=15, bd=5)
    ent.grid(row=row, column=1, pady=9, padx=10)
    ent.insert(0, 0)
    return ent

