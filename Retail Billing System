if not os.path.exists('bills'):
    os.mkdir('bills')


def print_bill():
    if textarea.get('1.0', END).strip() == '':
        messagebox.showerror('Error', 'Bill is empty')
    else:
        fd, file_path = tempfile.mkstemp('.txt')
        with open(file_path, 'w', encoding='utf-8') as f:
            f.write(textarea.get('1.0', END))
        try:
            os.startfile(os.path.abspath(file_path), 'print')
        except Exception:
            messagebox.showinfo('Printed', 'Bill written to temporary file for printing.')

def search_bill():
    bill_no = billnumberEntry.get().strip()
    for filename in os.listdir('bills/'):
        if filename.split('.')[0] == bill_no:
            with open(f'bills/{filename}', 'r', encoding='utf-8') as f:
                bill_data = f.read()
            textarea.delete('1.0', END)
            textarea.insert(END, bill_data)
            billnumberEntry.delete(0, END)
            billnumberEntry.insert(0, bill_no)
            break
    else:
        messagebox.showinfo(title='Bills not found', message='Bills not found')

def save_bill():
    billnumber = billnumberEntry.get()
    bill_data = textarea.get('1.0', END)
    if not billnumber:
        messagebox.showerror("Error", "Please enter a bill number before saving.")
        return
    with open(f"bills/{billnumber}.txt", "w", encoding='utf-8') as f:
        f.write(bill_data)
    messagebox.showinfo("Saved", f"Bill No. {billnumber} saved successfully")

def total():
    global bathsoapprice, facewashprice, facecreamprice, hairsprayprice, hairgelprice, bodylotionprice
    global totalcosmeticprice, cosmetictax
    global riceprice, oilprice, daalprice, wheatprice, sugarprice, teaprice, totalgroceryprice, grocerytax
    global maazaprice, pepsiprice, spriteprice, pulpyorangeprice, cococolaprice, frootiprice, totaldrinksprice, drinkstax
    global totalbill

    def to_int(entry):
        try:
            return int(entry.get())
        except Exception:
            return 0

    # Cosmetics
    bathsoap_q = to_int(bathsoapEntry)
    facewash_q = to_int(facewashEntry)
    facecream_q = to_int(facecreamEntry)
    hairspray_q = to_int(hairsprayEntry)
    hairgel_q = to_int(hairgelEntry)
    bodylotion_q = to_int(bodylotionEntry)

    bathsoapprice = bathsoap_q * 20
    facewashprice = facewash_q * 60
    facecreamprice = facecream_q * 100
    hairsprayprice = hairspray_q * 150
    hairgelprice = hairgel_q * 80
    bodylotionprice = bodylotion_q * 60

    totalcosmeticprice = (bathsoapprice + facewashprice + facecreamprice +
                          hairsprayprice + hairgelprice + bodylotionprice)
    cosmetictax = round(totalcosmeticprice * 0.05, 2)

    cosmeticpriceEntry.delete(0, END)
    cosmeticpriceEntry.insert(0, str(totalcosmeticprice) + ' Rs')
    cosmetictaxEntry.delete(0, END)
    cosmetictaxEntry.insert(0, str(cosmetictax) + ' Rs')

    # Grocery
    rice_q = to_int(riceEntry)
    oil_q = to_int(oilEntry)
    daal_q = to_int(daalEntry)
    wheat_q = to_int(wheatEntry)
    sugar_q = to_int(sugarEntry)
    tea_q = to_int(teaEntry)

    riceprice = rice_q * 30
    oilprice = oil_q * 100
    daalprice = daal_q * 120
    wheatprice = wheat_q * 80
    sugarprice = sugar_q * 50
    teaprice = tea_q * 140

    totalgroceryprice = riceprice + oilprice + daalprice + wheatprice + sugarprice + teaprice
    grocerytax = round(totalgroceryprice * 0.03, 2)

    grocerypriceEntry.delete(0, END)
    grocerypriceEntry.insert(0, str(totalgroceryprice) + ' Rs')
    grocerytaxEntry.delete(0, END)
    grocerytaxEntry.insert(0, str(grocerytax) + ' Rs')

    # Drinks
    maaza_q = to_int(maazaEntry)
    pepsi_q = to_int(pepsiEntry)
    sprite_q = to_int(spriteEntry)
    pulpy_q = to_int(pulpyorangeEntry)
    cococola_q = to_int(cococolaEntry)
    frooti_q = to_int(frootiEntry)

    maazaprice = maaza_q * 50
    pepsiprice = pepsi_q * 20
    spriteprice = sprite_q * 30
    pulpyorangeprice = pulpy_q * 20
    cococolaprice = cococola_q * 45
    frootiprice = frooti_q * 30

    totaldrinksprice = maazaprice + pepsiprice + spriteprice + pulpyorangeprice + cococolaprice + frootiprice
    drinkstax = round(totaldrinksprice * 0.08, 2)

    drinkspriceEntry.delete(0, END)
    drinkspriceEntry.insert(0, str(totaldrinksprice) + ' Rs')
    drinkstaxEntry.delete(0, END)
    drinkstaxEntry.insert(0, str(drinkstax) + ' Rs')

    # Final total
    totalbill = round(totalcosmeticprice + totalgroceryprice + totaldrinksprice + cosmetictax + grocerytax + drinkstax, 2)
    if billnumberEntry.get().strip() == "":
        billnumberEntry.insert(0, str(random.randint(500, 1000)))

def bill_area():
    # Basic validations
    if nameEntry.get().strip() == '' or phoneEntry.get().strip() == '':
        messagebox.showerror('Error', 'Customer Details Are Required')
        return

    total()
    try:
        cp = float(cosmeticpriceEntry.get().split()[0])
    except Exception:
        cp = 0.0
    try:
        gp = float(grocerypriceEntry.get().split()[0])
    except Exception:
        gp = 0.0
    try:
        dp = float(drinkspriceEntry.get().split()[0])
    except Exception:
        dp = 0.0

    if cp == 0 and gp == 0 and dp == 0:
        messagebox.showerror('Error', 'No products are selected')
        return

    # Build the bill text
    textarea.delete('1.0', END)
    textarea.insert(END, '\t\t**Welcome Customer**\n')
    textarea.insert(END, f'Bill Number: {billnumberEntry.get()}\n')
    textarea.insert(END, f'Customer Name: {nameEntry.get()}\n')
    textarea.insert(END, f'Customer phone number: {phoneEntry.get()}\n')
    textarea.insert(END, '\n=======================================================')
    textarea.insert(END, '\nproduct\t\tQuantity\t\tprice')
    textarea.insert(END, '\n=======================================================')

    def add_if(q_entry, price_value, label):
        try:
            q = int(q_entry.get())
        except Exception:
            q = 0
        if q != 0:
            textarea.insert(END, f'\n{label}\t\t{q}\t\t{price_value} Rs')

    add_if(bathsoapEntry, bathsoapprice, 'Bath soap')
    add_if(facewashEntry, facewashprice, 'Face wash')
    add_if(facecreamEntry, facecreamprice, 'Face cream')
    add_if(hairsprayEntry, hairsprayprice, 'Hair spray')
    add_if(hairgelEntry, hairgelprice, 'Hair gel')
    add_if(bodylotionEntry, bodylotionprice, 'Body lotion')

    add_if(riceEntry, riceprice, 'Rice')
    add_if(oilEntry, oilprice, 'Oil')
    add_if(daalEntry, daalprice, 'Daal')
    add_if(wheatEntry, wheatprice, 'Wheat')
    add_if(sugarEntry, sugarprice, 'Sugar')
    add_if(teaEntry, teaprice, 'Tea')

    add_if(maazaEntry, maazaprice, 'Maaza')
    add_if(pepsiEntry, pepsiprice, 'Pepsi')
    add_if(spriteEntry, spriteprice, 'Sprite')
    add_if(pulpyorangeEntry, pulpyorangeprice, 'Pulpy Orange')
    add_if(cococolaEntry, cococolaprice, 'Coco cola')
    add_if(frootiEntry, frootiprice, 'Frooti')

    textarea.insert(END, '\n-------------------------------------------------------')
    textarea.insert(END, f'\nCosmetic tax\t\t\t{cosmetictax} Rs')
    textarea.insert(END, f'\nGrocery tax\t\t\t{grocerytax} Rs')
    textarea.insert(END, f'\nDrinks tax\t\t\t{drinkstax} Rs')
    textarea.insert(END, '\n-------------------------------------------------------')
    textarea.insert(END, f'\nTotal Bill \t\t\t {totalbill} Rs')
    textarea.insert(END, '\n-------------------------------------------------------')

